# ─────────────────────────────────────────────────────────
# Environment Variables — copy to .env.local and fill in
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────

# ── Contact form (choose one) ──────────────────────────────
# Option A: Formspree (https://formspree.io)
NEXT_PUBLIC_FORMSPREE_ID=

# Option B: Resend (https://resend.com) — server-side
RESEND_API_KEY=
CONTACT_EMAIL_TO=hello@votrenom.fr

# ── Analytics ──────────────────────────────────────────────
# Vercel Analytics (free, no cookie consent needed in EU)
# Enable in vercel.json → no env needed

# Google Analytics 4 (optional)
NEXT_PUBLIC_GA_ID=

# ── Misc ───────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://votrenom.fr
